# Copy to .env and fill in values

# Backend origin (scheme + host + port). Example: http://localhost:8080
VITE_API_BASE_URL=http://localhost:8080

# API path prefix and versioning.
# This composes the Axios base URL as: ${VITE_API_BASE_URL}${VITE_API_PREFIX}/${VITE_API_VERSION}
VITE_API_PREFIX=/api
VITE_API_VERSION=v1
